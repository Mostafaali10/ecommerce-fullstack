# AR: انسخ هذا الملف إلى `.env` داخل مجلد `backend/` وعدّل القيم
# EN: Copy this file to `backend/.env` and adjust values for your machine.

# SQLite (default for learning). For Postgres: postgresql+psycopg2://user:pass@host:5432/dbname
DATABASE_URL=sqlite:///./ecommerce.db

# AR: مفتاح سري قوي في الإنتاج — لا ترفعه أبداً إلى Git
# EN: Use a strong random secret in production — never commit real secrets.
SECRET_KEY=change-me-to-a-long-random-string

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# AR: قائمة مفصولة بفواصل لأصول CORS المسموح بها، أو * للتجربة فقط
# EN: Comma-separated browser origins, or * for local experiments only.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
